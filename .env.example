# SSH 端口（对外暴露的唯一端口，iOS 客户端 SSH Tunnel 里填这个）
SSH_PORT=8008

# OpenCode 认证内容（1Password 引用，op run 解析后注入）
# 1Password 里存一个 Secure Note，内容是 opencode auth JSON：
# {"openai":{"type":"api","key":"sk-..."}}
OPENCODE_AUTH_CONTENT=op://your-vault/opencode/auth_content

# OpenCode 配置内容（可选，1Password 引用或直接写 JSON）
# 用于限制可用模型、配置 agent 等
# 示例：{"$schema":"https://opencode.ai/config.json","model":"openai/gpt-5.5"}
OPENCODE_CONFIG_CONTENT=op://your-vault/opencode/config_content