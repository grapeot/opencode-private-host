# SSH 端口（对外暴露的唯一端口，iOS 客户端 SSH Tunnel 里填这个）
SSH_PORT=8006

# OpenCode 镜像。默认使用公开 GHCR 镜像；本地测试也可以设为本地 tag。
OPENCODE_IMAGE=ghcr.io/your-github-username/opencode-private:latest

# OpenCode provider auth（可选）。OpenAI 默认由用户在 OpenCode web UI 自己连接。
# 这里仅用于未来注入非 OAuth provider，例如 ollama-cloud / GLM。
OPENCODE_AUTH_CONTENT=

# Tavily API key（1Password 引用，op run 解析后注入）
TAVILY_API_KEY=op://your-vault/tavily/api_key

# OpenCode 配置内容（可选，1Password 引用或直接写 JSON）
# 用于限制可用模型、配置 agent 等
# 示例：{"$schema":"https://opencode.ai/config.json","model":"openai/gpt-5.5"}
OPENCODE_CONFIG_CONTENT=op://your-vault/opencode/config_content
